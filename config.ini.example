[api]
base_url = http://100.88.175.20:1234/v1
api_key = dummy-key-for-local

[translation]
model = hy-mt1.5-1.8b
target_lang = Chinese
threads = 1

[display]
display_duration = 10
window_width = 800
window_height = 320

[transcription]
backend = mlx
whisper_model = tiny.en
funasr_model = iic/SenseVoiceSmall
device = cpu
compute_type = float32
source_language = en
transcription_workers = 1

[audio]
device_index = auto
sample_rate = 16000
silence_threshold = 0.005
silence_duration = 0.4
chunk_duration = 0.1
max_phrase_duration = 6
streaming_mode = true
streaming_interval = 2
streaming_step_size = 0.2
update_interval = 0.5
streaming_overlap = 0.3
final_overlap_duration = 0.6
